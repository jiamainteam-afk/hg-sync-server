# Copy these into Railway.app Environment Variables
# Never commit real values to git!

# Your Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Firebase Realtime Database URL
FIREBASE_URL=https://hg-invoices-default-rtdb.asia-southeast1.firebasedatabase.app

# Firebase Service Account JSON (get from Firebase Console → Project Settings → Service Accounts → Generate new private key)
# Paste the entire JSON as one line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"worker-loan",...}

# Secret token — Power Automate will send this in the header to verify it's really you
# Change this to something only you know!
WEBHOOK_SECRET=hg_cement_sync_2026
